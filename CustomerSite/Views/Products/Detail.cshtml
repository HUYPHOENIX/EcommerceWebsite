@model SharedViewModel.DTOs.ProductDto

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-secondary">
            &larr; Trờ về 
        </a>
    </div>

    <div class="row bg-white shadow-sm rounded p-4">
        @* Left Column: Big Image *@
        <div class="col-md-6 text-center">
            <img src="https://via.placeholder.com/600x400?text=No+Image" class="img-fluid rounded" alt="@Model.Name">
        </div>

        @* Right Column: Product Info *@
        <div class="col-md-6 d-flex flex-column justify-content-center">
            <h1 class="display-5 fw-bold text-dark">@Model.Name</h1>
            <h2 class="text-success fw-bold mb-4">$@Model.Price</h2>
            
            <p class="lead text-secondary mb-4">
                @Model.Description
            </p>

            @* --- NEW: COLOR SELECTION --- *@
            <form asp-controller="Cart" asp-action="Add" method="post">
                @* We hide the ProductId so the form sends it secretly in the background *@
                <input type="hidden" name="Id" value="@Model.Id" />

                @if (Model.Colors != null && Model.Colors.Any())
                {
                    <div class="mb-3">
                        <label class="fw-bold mb-2">Chọn màu:</label><br>
                        <div class="btn-group" role="group">
                            @foreach (var color in Model.Colors)
                            {
                                <input type="radio" class="btn-check" name="Color" id="@color" autocomplete="off" value="@color"
                                       required>
                                <label class="btn btn-outline-dark" for="@color">@color</label>
                            }
                        </div>
                    </div>
                }

                @* --- NEW: SIZE SELECTION --- *@
                @if (Model.Sizes != null && Model.Sizes.Any())
                {
                    <div class="mb-4">
                        <label class="fw-bold mb-2">Chọn Size:</label><br>
                        <div class="btn-group" role="group">
                            @foreach (var size in Model.Sizes)
                            {
                                <input type="radio" class="btn-check" name="Size" id="@size" autocomplete="off" value="@size"
                                       required>
                                <label class="btn btn-outline-secondary px-4" for="@size">@size</label>
                            }
                        </div>
                    </div>
                }
                @* --- NEW: QUANTITY SELECTION --- *@
                <div class="mb-4">
                    <label class="fw-bold mb-2">Quantity:</label>
                    <input type="number" name="Quantity" class="form-control form-control-lg w-25" value="1" min="1"
                           max="99" required>
                </div>
                <div class="d-grid gap-2 mt-auto">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold">Thêm vào giỏ hàng</button>
                </div>
            </form>
        </div>
    </div>
</div>